{
  "name": "polarbear",
  "private": true,
  "description": "Polarbear is a local-first Markdown editor for writers, developers, and GitHub-based knowledge workflows.",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "lint": "npm --workspace apps/desktop run lint",
    "test": "npm --workspace apps/desktop run test",
    "typecheck": "npm --workspace apps/desktop run typecheck",
    "build": "npm --workspace apps/desktop run build",
    "tauri": "npm --workspace apps/desktop run tauri --",
    "tauri:dev": "npm --workspace apps/desktop run tauri -- dev",
    "tauri:build": "npm --workspace apps/desktop run tauri -- build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
