    "@codemirror/view": "^6.43.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@uiw/react-codemirror": "^4.23.13",
    "dompurify": "^3.4.12",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/markdown-it": "^14.1.2",
