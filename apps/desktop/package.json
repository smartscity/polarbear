{
  "name": "polarbear-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Polarbear desktop app - a local-first Markdown editor powered by Rust, Tauri, and TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420 --strictPort",
