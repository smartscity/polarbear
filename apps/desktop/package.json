    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "rollup": "^4.52.5",
    "typescript": "^5.8.3",
